{
  "name": "staccato",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "preview": "pnpm build && pnpm --filter @staccato/server start",
    "studio": "pnpm --filter @staccato/server run studio",
    "inspect-tags": "pnpm --filter @staccato/server run inspect-tags"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
